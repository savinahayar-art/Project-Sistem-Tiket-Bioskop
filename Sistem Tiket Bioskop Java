    // ================= LINEAR SEARCH =================
    static void linearSearchNama() {

        System.out.print("Cari Nama Film: ");
        String cari = sc.nextLine();

        boolean ketemu = false;

        for (int i = 0; i < n; i++) {

            if (data[i].aktif &&
                    data[i].namaFilm.equalsIgnoreCase(cari)) {

                System.out.println(
                        ">> Ditemukan: " +
                        data[i].namaFilm
                );

                ketemu = true;
            }
        }

        if (!ketemu) {

            System.out.println(">> Film tidak ditemukan!");
        }
    }

    // ================= BUBBLE SORT ID =================
    static void bubbleSortID() {

        for (int i = 0; i < n - 1; i++) {

            for (int j = 0; j < n - i - 1; j++) {

                if (data[j].id > data[j + 1].id) {

                    Tiket temp = data[j];
                    data[j] = data[j + 1];
                    data[j + 1] = temp;
                }
            }
        }

        System.out.println(">> Data berhasil diurutkan berdasarkan ID!");

        tampilData();
    }

    // ================= SELECTION SORT NAMA =================
    static void selectionSortNama() {

        for (int i = 0; i < n - 1; i++) {

            int min = i;

            for (int j = i + 1; j < n; j++) {

                if (data[j].namaFilm.compareToIgnoreCase(
                        data[min].namaFilm) < 0) {

                    min = j;
                }
            }

            Tiket temp = data[i];
            data[i] = data[min];
            data[min] = temp;
        }

        System.out.println(">> Data berhasil diurutkan berdasarkan Nama!");

        tampilData();
    }

    // ================= SORT JUMLAH TIKET =================
    static void sortJumlahTiket() {

        for (int i = 0; i < n - 1; i++) {

            for (int j = 0; j < n - i - 1; j++) {

                if (data[j].jumlahTiket >
                        data[j + 1].jumlahTiket) {

                    Tiket temp = data[j];
                    data[j] = data[j + 1];
                    data[j + 1] = temp;
                }
            }
        }

        System.out.println(
                ">> Data berhasil diurutkan berdasarkan jumlah tiket!"
        );

        tampilData();
    }

    // ================= BINARY SEARCH =================
    static int binarySearchID(int id) {

        int left = 0;
        int right = n - 1;

        while (left <= right) {

            int mid = (left + right) / 2;

            if (data[mid].id == id) {

                return mid;
            }

            else if (data[mid].id < id) {

                left = mid + 1;
            }

            else {

                right = mid - 1;
            }
        }

        return -1;
    }

