        int tersedia = 0;

        for (int i = 0; i < n; i++) {

            if (data[i].aktif) {

                total++;

                if (data[i].jumlahTiket > 0) {

                    tersedia++;
                }
            }
        }

        System.out.println("\n=== STATISTIK ===");
        System.out.println("Total Film Aktif : " + total);
        System.out.println("Film Tersedia    : " + tersedia);
    }

