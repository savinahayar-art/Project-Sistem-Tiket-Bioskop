    // ================= BELI TIKET =================
    static void beliTiket() {

        try {

            System.out.print("Masukkan ID Film: ");
            int id = Integer.parseInt(sc.nextLine());

            boolean ketemu = false;

            for (int i = 0; i < n; i++) {

                if (data[i].id == id && data[i].aktif) {

                    ketemu = true;

                    System.out.println(
                            "Film: " + data[i].namaFilm
                    );

                    System.out.println(
                            "Stok Tiket: " +
                            data[i].jumlahTiket
                    );

                    System.out.print(
                            "Jumlah tiket dibeli: "
                    );

                    int beli =
                            Integer.parseInt(sc.nextLine());

                    // Validasi jumlah tiket
                    if (beli <= 0) {

                        System.out.println(
                                ">> Jumlah tiket tidak valid!"
                        );
                    }

                    else if (beli >
                            data[i].jumlahTiket) {

                        System.out.println(
                                ">> Stok tiket tidak mencukupi!"
                        );
                    }

                    else {

                        data[i].jumlahTiket -= beli;

                        System.out.println(
                                ">> Tiket berhasil dibeli!"
                        );

                        System.out.println(
                                ">> Sisa tiket: " +
                                data[i].jumlahTiket
                        );
                    }

                    return;
                }
            }

            if (!ketemu) {

                System.out.println(
                        ">> Film tidak ditemukan!"
                );
            }

        } catch (Exception e) {

            System.out.println(">> Input tidak valid!");
        }
    }

    // ================= STATISTIK =================
